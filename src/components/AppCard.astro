---
export interface Props {
  name: string;
  description: string;
  icon: string;
  appStoreUrl: string;
  category: string;
  price: string;
  rating?: number;
  downloads?: string;
}

const { name, description, icon, appStoreUrl, category, price, rating, downloads } = Astro.props;
---

<div class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 overflow-hidden group hover:-translate-y-1">
  <div class="p-6">
    <div class="flex items-start space-x-4">
      <div class="flex-shrink-0">
        <div class="w-16 h-16 bg-gradient-to-br from-blue-100 to-indigo-100 rounded-xl flex items-center justify-center text-2xl transition-transform duration-300 group-hover:scale-110">
          {icon}
        </div>
      </div>
      
      <div class="flex-1 min-w-0">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-primary transition-colors duration-300">
            {name}
          </h3>
          <span class="text-sm font-medium text-gray-500">{price}</span>
        </div>
        
        <p class="text-sm text-gray-600 mb-3 line-clamp-2">
          {description}
        </p>
        
        <div class="flex items-center justify-between">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 transition-colors duration-300 group-hover:bg-blue-200">
            {category}
          </span>
          
          {rating && (
            <div class="flex items-center space-x-1">
              <span class="text-yellow-400 transition-transform duration-300 group-hover:scale-110">⭐</span>
              <span class="text-sm text-gray-600">{rating}</span>
            </div>
          )}
        </div>
        
        {downloads && (
          <p class="text-xs text-gray-500 mt-2">
            {downloads} downloads
          </p>
        )}
      </div>
    </div>
    
    <div class="mt-4 pt-4 border-t border-gray-100">
      <a 
        href={appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full inline-flex items-center justify-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary/90 transition-all duration-300 hover:scale-105 active:scale-95"
      >
        📱 View on App Store
      </a>
    </div>
  </div>
</div>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
