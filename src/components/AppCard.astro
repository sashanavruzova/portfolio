---
export interface Props {
  name: string;
  description: string;
  icon: string;
  appStoreUrl: string;
  category: string;
  price: string;
  rating?: number;
  downloads?: string;
  isRealData?: boolean;
  country?: string;
  currency?: string;
}

const { name, description, icon, appStoreUrl, category, price, rating, downloads, isRealData = false, country, currency } = Astro.props;

// Truncate description if it's too long
const truncatedDescription = description.length > 150 ? description.substring(0, 150) + '...' : description;

// Country display names
const countryNames: { [key: string]: string } = {
  'us': '🇺🇸',
  'il': '🇮🇱',
  'de': '🇩🇪',
  'gb': '🇬🇧',
  'ca': '🇨🇦',
  'au': '🇦🇺'
};
---

<div class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border border-purple-100 overflow-hidden group hover:-translate-y-1">
  <div class="p-6">
    <div class="flex items-start space-x-4">
      <div class="flex-shrink-0">
        {isRealData && icon.startsWith('http') ? (
          <img 
            src={icon} 
            alt={`${name} icon`}
            class="w-16 h-16 rounded-xl object-cover transition-transform duration-300 group-hover:scale-110"
            loading="lazy"
          />
        ) : (
          <div class="w-16 h-16 bg-gradient-to-br from-purple-100 to-pink-100 rounded-xl flex items-center justify-center text-2xl transition-transform duration-300 group-hover:scale-110">
            {icon}
          </div>
        )}
      </div>
      
      <div class="flex-1 min-w-0">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-lg font-semibold text-gray-900 group-hover:text-primary transition-colors duration-300">
            {name}
          </h3>
          <div class="flex items-center space-x-2">
            {country && countryNames[country] && (
              <span class="text-sm" title={`${country.toUpperCase()} App Store`}>
                {countryNames[country]}
              </span>
            )}
            <span class="text-sm font-medium text-gray-500">{price}</span>
          </div>
        </div>
        
        <p class="text-sm text-gray-600 mb-3 line-clamp-2">
          {truncatedDescription}
        </p>
        
        <div class="flex items-center justify-between">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800 transition-colors duration-300 group-hover:bg-purple-200">
            {category}
          </span>
          
          {rating && rating > 0 && (
            <div class="flex items-center space-x-1">
              <span class="text-yellow-400 transition-transform duration-300 group-hover:scale-110">⭐</span>
              <span class="text-sm text-gray-600">{rating.toFixed(1)}</span>
              {downloads && (
                <span class="text-xs text-gray-500 ml-1">({downloads})</span>
              )}
            </div>
          )}
        </div>
        
        {/* Show currency info if available */}
        {currency && currency !== 'USD' && (
          <p class="text-xs text-gray-500 mt-2">
            Prices in {currency}
          </p>
        )}
      </div>
    </div>
    
    <div class="mt-4 pt-4 border-t border-purple-100">
      <a 
        href={appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full inline-flex items-center justify-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary/90 transition-all duration-300 hover:scale-105 active:scale-95"
      >
        📱 View on App Store
      </a>
    </div>
  </div>
</div>
