---
import AppCard from './AppCard.astro';
import { fetchMultipleApps, getUserCountry } from '../utils/appStore';

// App IDs from App Store URLs
const appIds = [
  "6723894973" // Verbly - Learn Hebrew
  // Add more app IDs here as you develop them
];

// Get user's country for personalized data
const userCountry = getUserCountry();

// Fetch app data from App Store
let apps: any[] = [];
try {
  apps = await fetchMultipleApps(appIds, userCountry);
} catch (error) {
  console.error('Error fetching apps:', error);
  // Fallback to static data if API fails
  apps = [{
    trackId: "6723894973",
    trackName: "Verbly - Learn Hebrew",
    description: "Master Hebrew Verbs One Day at a Time! Learn essential Hebrew verbs daily with an intuitive and stress-free approach. Features daily verbs, flashcards, progress tracking, and offline learning.",
    artworkUrl100: "/verbly-icon.png", // Fallback icon
    averageUserRating: 5.0,
    userRatingCount: 1,
    price: 0,
    formattedPrice: "Free",
    primaryGenreName: "Education",
    trackViewUrl: "https://apps.apple.com/il/app/learn-hebrew-daily-verbs-app/id6723894973",
    country: "us",
    currency: "USD"
  }];
}

// Country display names
const countryNames: { [key: string]: string } = {
  'us': 'United States',
  'il': 'Israel',
  'de': 'Germany',
  'gb': 'United Kingdom',
  'ca': 'Canada',
  'au': 'Australia'
};
---

<section id="apps" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-fade-in-up">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        My Apps 🚀
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Here are the mobile apps I've built to help people learn, grow, and be more productive.
      </p>
      
      {/* Show which store data is being displayed */}
      {apps.length > 0 && apps[0].country && (
        <div class="mt-4 inline-flex items-center px-3 py-1 bg-purple-100 text-purple-800 rounded-full text-sm">
          <span class="mr-2">📍</span>
          <span>Showing data from {countryNames[apps[0].country] || apps[0].country.toUpperCase()} App Store</span>
        </div>
      )}
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {apps.map((app, index) => (
        <div class="animate-fade-in-up" style={`animation-delay: ${index * 0.1}s`}>
          <AppCard 
            name={app.trackName}
            description={app.description}
            icon={app.artworkUrl100}
            appStoreUrl={app.trackViewUrl}
            category={app.primaryGenreName}
            price={app.formattedPrice}
            rating={app.averageUserRating}
            downloads={`${app.userRatingCount}+`}
            isRealData={true}
            country={app.country}
            currency={app.currency}
          />
        </div>
      ))}
    </div>
    
    <div class="text-center mt-12 animate-fade-in-up-delay-1">
      <p class="text-gray-600 mb-4">
        More apps coming soon! 🎯
      </p>
      <a 
        href="mailto:alnavruzova@gmail.com" 
        class="inline-flex items-center px-6 py-3 border-2 border-primary text-primary font-medium rounded-lg hover:bg-primary hover:text-white transition-all duration-300 hover:scale-105"
      >
        💡 Have an idea? Let's talk!
      </a>
    </div>
  </div>
</section>
