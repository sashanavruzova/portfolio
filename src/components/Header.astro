---
const currentPath = Astro.url.pathname;
---

<header class="bg-white shadow-sm border-b border-gray-100 sticky top-0 z-50 animate-slide-down">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center">
        <a href="/" class="text-xl font-bold text-gray-900 hover:text-primary transition-colors duration-300">
          Sasha Navruzova
        </a>
      </div>
      
      <nav class="hidden md:flex space-x-8">
        <a href="/" class={`text-sm font-medium transition-colors duration-300 ${currentPath === '/' ? 'text-primary' : 'text-gray-600 hover:text-primary'}`}>
          Home
        </a>
        <a href="/terms" class={`text-sm font-medium transition-colors duration-300 ${currentPath === '/terms' ? 'text-primary' : 'text-gray-600 hover:text-primary'}`}>
          Terms
        </a>
        <a href="/privacy" class={`text-sm font-medium transition-colors duration-300 ${currentPath === '/privacy' ? 'text-primary' : 'text-gray-600 hover:text-primary'}`}>
          Privacy
        </a>
      </nav>
    </div>
  </div>
</header>
